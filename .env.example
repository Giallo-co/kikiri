# Puerto del servidor
PORT=3000

# Entorno: development | production | test
NODE_ENV=development

# Mínimo de longitud de password al registrar
MIN_PASSWORD_LENGTH=8

# Prefijo/base path de las rutas del API de usuario
# Ej: /user, /api/v1/user
API_BASE_PATH=/user

# Host y protocolo usados para el log/URL (y para despliegue)
HOST=localhost
PROTOCOL=http

# Mensaje genérico para errores 500
ERROR_MESSAGE=Something broke!

# --- Docker DB (local) ---
# MySQL (service: mysql, port: 3306)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=social-media

# DynamoDB Local (service: dynamodb, port: 8000)
DYNAMODB_HOST=localhost
DYNAMODB_PORT=8000
DYNAMODB_ENDPOINT=http://localhost:8000

